---
import { Icon } from "astro-icon/components";

interface ContactItem {
  icon: string;
  label: string;
  value: string;
  href: string;
}

const contactItems: ContactItem[] = [
  {
    icon: "tabler:mail",
    label: "Correo electrónico",
    value: "caruajulcamartin9@gmail.com",
    href: "mailto:caruajulcamartin9@gmail.com",
  },
  {
    icon: "tabler:brand-github",
    label: "GitHub",
    value: "github.com/CaruajulcaMartin",
    href: "https://github.com/CaruajulcaMartin",
  },
  {
    icon: "tabler:brand-linkedin",
    label: "LinkedIn",
    value: "linkedin.com/in/Luis-Caruajulca-Rimarachin",
    href: "https://www.linkedin.com/in/luis-martin-caruajulca-rimarachin/",
  },
];
---

<section
  id="contacto"
  class="py-20 lg:py-28 relative overflow-hidden"
  aria-labelledby="contact-heading"
>
  <!-- Background blob -->
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-96 blob-primary opacity-50 pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="container mx-auto max-w-7xl px-4 sm:px-6 relative z-10">
    <!-- Section header -->
    <div class="mb-10 lg:mb-14 reveal-on-scroll">
      <div class="flex items-center gap-3 mb-3">
        <span
          class="text-xs font-mono font-semibold text-primary tracking-widest uppercase"
        >
          05 · Contacto
        </span>
        <div class="flex-1 h-px bg-border max-w-24" aria-hidden="true"></div>
      </div>
      <h2
        id="contact-heading"
        class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-foreground"
      >
        Hablemos
      </h2>
      <p class="mt-3 text-base text-muted-foreground max-w-lg">
        ¿Tienes un proyecto en mente o una oportunidad? Estoy disponible y listo
        para escucharte.
      </p>
    </div>

    <!-- Single column layout con todos los contactos -->
    <div class="max-w-3xl mx-auto reveal-on-scroll">
      <!-- Availability status -->
      <div class="p-6 bg-primary/5 border border-primary/20 rounded-2xl mb-8">
        <div class="flex items-center gap-3 mb-2">
          <div
            class="w-2.5 h-2.5 bg-green-400 rounded-full animate-pulse"
            aria-hidden="true"
          >
          </div>
          <span class="text-sm font-semibold text-foreground"
            >Disponible para proyectos</span
          >
        </div>
        <p class="text-sm text-muted-foreground">
          Abierto a posiciones Full Stack, colaboraciones remotas y proyectos
          freelance.
        </p>
      </div>

      <!-- Contact items en grid de 2 columnas -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          contactItems.map((item) => (
            <a
              href={item.href}
              target={item.href.startsWith("mailto") ? undefined : "_blank"}
              rel={
                item.href.startsWith("mailto")
                  ? undefined
                  : "noopener noreferrer"
              }
              class="flex items-center gap-4 p-5 bg-card border border-border rounded-xl hover:border-primary/40 hover:bg-muted/30 transition-all group"
              aria-label={`${item.label}: ${item.value}`}
            >
              <div class="w-11 h-11 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
                <Icon name={item.icon} size={20} class="text-primary" />
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-xs text-muted-foreground mb-0.5">
                  {item.label}
                </div>
                <div class="text-sm font-mono font-medium text-foreground truncate">
                  {item.value}
                </div>
              </div>
              <Icon
                name="tabler:arrow-right"
                size={16}
                class="text-muted-foreground shrink-0 group-hover:translate-x-1 transition-transform"
              />
            </a>
          ))
        }
      </div>

      <!-- Response time note -->
      <div
        class="mt-8 flex items-start gap-3 p-4 bg-muted/30 border border-border/50 rounded-xl"
      >
        <Icon
          name="tabler:clock"
          size={16}
          class="text-muted-foreground mt-0.5 shrink-0"
        />
        <p class="text-xs text-muted-foreground leading-relaxed">
          Respondo en menos de 24 horas. Para consultas urgentes, escríbeme
          directamente al correo.
        </p>
      </div>

      <!-- CTA adicional -->
      <div class="mt-8 text-center">
        <p class="text-sm text-muted-foreground">
          ¿Prefieres contactarme directamente?
          <a
            href="mailto:caruajulcamartin9@gmail.com"
            class="text-primary font-medium hover:underline"
          >
            Escríbeme un correo
          </a>
        </p>
      </div>
    </div>
  </div>
</section>